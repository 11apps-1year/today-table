# Local PoC defaults.
# Local development uses mock auth + SQLite when these are not set.
AUTH_MODE=mock
NEXT_PUBLIC_AUTH_MODE=mock
MEAL_REPOSITORY=sqlite
SQLITE_DATABASE_PATH=data/today-table.local.db

# Firebase web client config, used by apps/web for Google sign-in.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin config, used server-side by packages/firebase-storage.
# Prefer ADC in deployed environments. For local PoC, base64-encode a service account JSON file:
# base64 -i firebase-service-account.json | pbcopy
FIREBASE_SERVICE_ACCOUNT_BASE64=
FIREBASE_STORAGE_BUCKET=
